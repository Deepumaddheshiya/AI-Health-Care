{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "functions": {
        "api/**/*.js": {
            "includeFiles": "server/hospital_directory.csv"
        }
    },
    "rewrites": [
        {
            "source": "/api/hello",
            "destination": "/api/hello"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/health",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/$1"
        }
    ]
}